    "/animals": {
      "post": {
        "summary": "Create a new animal",
        "tags": [
          "Animals"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "description": "Creates a new animal record. Accessible to admin and staff users only.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "species",
                  "age",
                  "gender"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "species": {
                    "type": "string"
                  },
                  "breed": {
                    "type": "string"
                  },
                  "age": {
                    "type": "number",
                    "minimum": 0
                  },
                  "gender": {
                    "type": "string",
                    "enum": [
                      "male",
                      "female"
                    ]
                  },
                  "healthStatus": {
                    "type": "string",
                    "enum": [
                      "healthy",
                      "injured",
                      "sick"
                    ],
                    "default": "healthy"
                  },
                  "isAdopted": {
                    "type": "boolean",
                    "default": false
                  },
                  "description": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Animal created successfully",
