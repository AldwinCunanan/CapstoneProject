              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Adopter retrieved successfully"
                    },
                    "data": {
                      "$ref": "#/components/schemas/Adopter"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Adopter not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Update an adopter",
        "tags": [
          "Adopters"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "description": "Only admins can update adopters",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Adopter ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateAdopterRequest"
              }
